{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "**/*.docx",
      "**/*.xlsx",
      ".git",
      ".github",
      "Solicitações de maquina de lavar louças",
      "*.md",
      "Credenciais*",
      "Guia*",
      "INSTRUCOES*",
      "RESUMO*",
      "AVALIACAO*",
      "FLUXO*",
      "DATABASE*",
      "PERFIS*",
      "README*",
      "CHANGELOG*",
      "CONFIGURAR*",
      "RELATORIO*",
      "COMO_ACESSAR*",
      "CORRECAO*",
      "LIMPAR_CACHE*",
      "mudancas*",
      "analise*",
      "admin_firebase*",
      "criar_usuarios*",
      "workrail.html",
      "workrail_app.html",
      "criar_admin_firebase.html"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/workrail_v2.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "**/*.{js,css}",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=3600"
          }
        ]
      }
    ]
  }
}
